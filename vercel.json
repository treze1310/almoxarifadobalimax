{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/sistema",
      "destination": "/sistema/index.html"
    },
    {
      "source": "/sistema/(.*)",
      "destination": "/sistema/index.html"
    }
  ]
}